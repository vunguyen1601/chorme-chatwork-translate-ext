{
  "manifest_version": 3,
  "name": "Chatwork Translate",
  "version": "0.1.0",
  "description": "Two-way translation inside Chatwork.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.chatwork.com/*"],
  "action": { "default_popup": "src/popup/popup.html" },
  "background": { "service_worker": "src/background/service-worker.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["*://*.chatwork.com/*"],
      "js": ["src/content/loader.js"],
      "css": ["src/content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/*.js", "src/adapters/*.js", "src/shared/*.js"],
      "matches": ["*://*.chatwork.com/*"]
    }
  ]
}
